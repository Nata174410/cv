---
import { profile, navLinks } from '../data/cv';
---

<nav
  class="bg-surface-container-lowest border-b border-border-subtle sticky top-0 w-full z-50 flex justify-between items-center px-margin-mobile md:px-margin-desktop h-20 max-w-container-max mx-auto shadow-sm"
>
  <a
    class="font-headline-md text-headline-md font-bold text-primary hover:opacity-80 transition-opacity"
    href="#home"
  >
    {profile.brand}
  </a>

  <div class="hidden md:flex gap-8 items-center h-full">
    {
      navLinks.map((link, i) => (
        <a
          class={
            i === 0
              ? 'text-primary font-bold border-b-2 border-primary pb-1 h-full flex items-center hover:opacity-80 transition-opacity'
              : 'text-on-surface-variant font-medium hover:text-primary hover:opacity-80 transition-opacity h-full flex items-center'
          }
          href={link.href}
        >
          {link.label}
        </a>
      ))
    }
  </div>

  <a
    class="hidden md:inline-flex bg-primary-container text-on-primary px-6 py-2 rounded font-label-sm text-label-sm hover:opacity-90 transition-opacity shadow-sm"
    href="#contact"
  >
    Contáctame
  </a>

  <!-- Botón menú móvil -->
  <button id="mobile-menu-btn" class="md:hidden text-primary" aria-label="Abrir menú">
    <span class="material-symbols-outlined text-2xl">menu</span>
  </button>
</nav>

<!-- Menú móvil desplegable -->
<div
  id="mobile-menu"
  class="hidden md:hidden bg-surface-container-lowest border-b border-border-subtle sticky top-20 w-full z-40 max-w-container-max mx-auto"
>
  <div class="flex flex-col px-margin-mobile py-4 gap-1">
    {
      navLinks.map((link) => (
        <a
          class="text-on-surface-variant font-medium hover:text-primary py-2 transition-colors"
          href={link.href}
          data-mobile-link
        >
          {link.label}
        </a>
      ))
    }
  </div>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  document
    .querySelectorAll('[data-mobile-link]')
    .forEach((l) => l.addEventListener('click', () => menu?.classList.add('hidden')));
</script>
