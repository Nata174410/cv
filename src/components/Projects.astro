---
import { projects } from '../data/cv';
---

<section
  id="projects"
  class="py-section-gap px-margin-mobile md:px-margin-desktop bg-surface-bg border-y border-border-subtle"
>
  <div class="mb-12 text-center" data-reveal>
    <h2 class="font-headline-lg text-headline-lg text-primary mb-4">Galería de Proyectos</h2>
    <div class="accent-bar w-16 h-1 bg-secondary mx-auto" style="transform-origin: center"></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    {
      projects.map((project, i) => (
        <div
          class="lift group bg-surface-container-lowest border border-border-subtle rounded-lg overflow-hidden hover:shadow-[0_8px_24px_rgba(0,45,98,0.08)]"
          data-reveal
          style={`--reveal-delay: ${i * 120}ms`}
        >
          <div class="h-48 bg-surface-container flex items-center justify-center overflow-hidden">
            <span class="material-symbols-outlined text-6xl text-primary-container transition-transform duration-300 group-hover:scale-110">
              {project.icon}
            </span>
          </div>
          <div class="p-6">
            <h4 class="font-headline-md text-[20px] text-primary mb-2">{project.title}</h4>
            <p class="font-body-md text-body-md text-on-surface-variant">{project.description}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>
