---
import { profile } from '../data/cv';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const photo = `${base}/yennifer.jpg`;
---

<section
  id="home"
  class="relative py-section-gap px-margin-mobile md:px-margin-desktop hero-pattern overflow-hidden min-h-[819px] flex items-center border-b border-border-subtle"
>
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter items-center relative z-10 w-full">
    <div class="lg:col-span-7 flex flex-col items-start space-y-6">
      <span class="font-label-caps text-label-caps text-secondary tracking-widest uppercase">
        {profile.name}
      </span>
      <h1 class="font-headline-display text-headline-display text-primary max-w-4xl">
        {profile.role}
      </h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl leading-relaxed">
        {profile.tagline}
      </p>
      <div class="flex flex-wrap gap-4 pt-4">
        <a
          class="bg-primary-container text-on-primary px-8 py-3 rounded font-label-sm text-label-sm hover:opacity-90 transition-opacity shadow-sm"
          href="#contact"
        >
          Contáctame
        </a>
        <a
          class="bg-transparent text-secondary border border-secondary px-8 py-3 rounded font-label-sm text-label-sm hover:bg-surface-container transition-colors"
          href="#experience"
        >
          Ver Trayectoria
        </a>
      </div>
    </div>

    <!-- Foto de perfil -->
    <div class="lg:col-span-5 flex justify-center lg:justify-end">
      <div class="relative">
        <!-- Acento geométrico (datos / precisión) -->
        <div
          class="absolute -top-4 -left-4 w-24 h-24 border-t-2 border-l-2 border-secondary opacity-60 hidden lg:block"
        >
        </div>
        <div
          class="absolute -bottom-4 -right-4 w-24 h-24 border-b-2 border-r-2 border-primary-container opacity-60 hidden lg:block"
        >
        </div>
        <div
          class="bg-surface-container-lowest border border-border-subtle rounded-lg p-2 shadow-[0_4px_24px_rgba(0,45,98,0.10)]"
        >
          <img
            src={photo}
            alt={`Fotografía de ${profile.name}, ${profile.role}`}
            width="767"
            height="900"
            loading="eager"
            decoding="async"
            class="rounded-lg w-full max-w-[360px] object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</section>
