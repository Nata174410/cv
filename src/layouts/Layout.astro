---
import '../styles/global.css';
import { profile, seo, contact } from '../data/cv';

interface Props {
  title?: string;
  description?: string;
}

const { title = seo.title, description = seo.description } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// URL canónica absoluta (Astro.site + base + path)
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://Nata174410.github.io/').href;
const ogImageUrl = new URL(`${base}/${seo.ogImage}`, Astro.site ?? 'https://Nata174410.github.io/').href;
const email = contact.channels.find((c) => c.href.startsWith('mailto:'))?.href ?? '';

// Datos estructurados (schema.org) en un @graph: Person + ProfilePage + WebSite.
// Refuerza la identidad de Natalia ante Google (Knowledge Graph, sitename).
const personId = `${canonical}#natalia`;
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': personId,
      name: profile.name,
      alternateName: seo.alternateName,
      jobTitle: profile.role,
      description: seo.description,
      image: ogImageUrl,
      url: canonical,
      email,
      sameAs: seo.sameAs,
      knowsAbout: ['NIIF / IFRS', 'Power BI', 'Análisis de Datos', 'Facturación Electrónica', 'Nómina', 'Tributario', 'Auditoría'],
      worksFor: { '@type': 'Organization', name: 'Reciclajes Bogotá NS SAS' },
      alumniOf: [
        { '@type': 'CollegeOrUniversity', name: 'Fundación Universitaria Los Libertadores' },
        { '@type': 'EducationalOrganization', name: 'SENA' },
      ],
      address: { '@type': 'PostalAddress', addressLocality: 'Bogotá', addressCountry: 'CO' },
    },
    {
      '@type': 'ProfilePage',
      '@id': `${canonical}#webpage`,
      url: canonical,
      name: seo.title,
      about: { '@id': personId },
      inLanguage: 'es',
    },
    {
      '@type': 'WebSite',
      url: canonical,
      name: `${profile.name} — ${profile.role}`,
      inLanguage: 'es',
    },
  ],
};
---

<!doctype html>
<html class="scroll-smooth" lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={seo.keywords.join(', ')} />
    <meta name="author" content={profile.name} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content={seo.themeColor} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph (Facebook, LinkedIn, WhatsApp) -->
    <meta property="og:type" content="profile" />
    <meta property="og:site_name" content={profile.brand} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={seo.locale} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${profile.name} — ${profile.role}`} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Iconos / PWA -->
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}/site.webmanifest`} />

    <!-- Datos estructurados -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,200..900;1,200..900&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="bg-background text-on-surface font-body-md antialiased selection:bg-primary-container selection:text-on-primary"
  >
    <slot />

    <script>
      // Reveal on scroll: muestra los elementos [data-reveal] al entrar en viewport.
      const els = document.querySelectorAll('[data-reveal]');
      if (!('IntersectionObserver' in window)) {
        els.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
