---
import { contact, cvDownloads } from '../data/cv';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section
  id="contact"
  class="py-section-gap px-margin-mobile md:px-margin-desktop bg-surface-bg border-t border-border-subtle text-center flex flex-col items-center"
>
  <h2 class="font-headline-lg text-headline-lg text-primary mb-4" data-reveal>Contacto</h2>
  <div class="accent-bar w-16 h-1 bg-secondary mb-12" style="transform-origin: center" data-reveal></div>
  <p class="font-body-lg text-body-lg text-on-surface-variant max-w-xl mb-8" data-reveal style="--reveal-delay: 100ms">
    {contact.intro}
  </p>
  <div class="flex flex-col md:flex-row gap-6 justify-center items-center">
    {
      contact.channels.map((channel, i) => (
        <a
          class="lift flex items-center gap-3 bg-surface-container-lowest border border-border-subtle px-6 py-4 rounded-lg hover:border-primary hover:shadow-[0_8px_24px_rgba(0,45,98,0.08)] min-w-[250px]"
          href={channel.href}
          target={channel.href.startsWith('http') ? '_blank' : undefined}
          rel={channel.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          data-reveal
          style={`--reveal-delay: ${i * 120}ms`}
        >
          <span class="material-symbols-outlined text-primary-container">{channel.icon}</span>
          <span class="font-label-sm text-label-sm text-primary">{channel.label}</span>
        </a>
      ))
    }
  </div>

  <!-- Descarga de hoja de vida (ES / EN) -->
  <div class="mt-12 flex flex-col items-center" data-reveal style="--reveal-delay: 200ms">
    <span class="font-label-caps text-label-caps text-outline uppercase tracking-widest mb-4">
      Descargar Hoja de Vida
    </span>
    <div class="flex flex-col sm:flex-row gap-4">
      {
        cvDownloads.map((cv) => (
          <a
            class="lift inline-flex items-center gap-2 bg-primary-container text-on-primary px-6 py-3 rounded font-label-sm text-label-sm hover:opacity-90 shadow-sm"
            href={`${base}/${cv.file}`}
            download
          >
            <span class="material-symbols-outlined text-[20px]">download</span>
            {cv.label}
            <span class="opacity-70">· PDF</span>
          </a>
        ))
      }
    </div>
  </div>
</section>
