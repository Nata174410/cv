---
import { profile, navLinks, cvDownloads } from '../data/cv';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<nav
  class="bg-surface-container-lowest border-b border-border-subtle sticky top-0 w-full z-50 flex justify-between items-center px-margin-mobile md:px-margin-desktop h-20 max-w-container-max mx-auto shadow-sm"
>
  <a
    class="flex flex-col leading-none hover:opacity-80 transition-opacity"
    href="#home"
    aria-label={`${profile.name} — ${profile.role}`}
  >
    <span class="font-headline-md text-[20px] font-bold text-primary whitespace-nowrap">
      {profile.brand}
    </span>
    <span
      class="font-label-caps text-label-caps text-secondary uppercase tracking-[0.2em] mt-1 whitespace-nowrap"
    >
      {profile.brandTagline}
    </span>
  </a>

  <div class="hidden md:flex gap-5 lg:gap-7 items-center h-full mx-auto px-6">
    {
      navLinks.map((link, i) => (
        <a
          class:list={['nav-link', { 'is-active': i === 0 }]}
          href={link.href}
          data-nav={link.href.slice(1)}
        >
          {link.label}
        </a>
      ))
    }
  </div>

  <!-- CTA: Descargar CV (ES / EN) -->
  <div class="hidden md:block relative group">
    <button
      class="inline-flex items-center gap-1.5 bg-primary-container text-on-primary px-5 py-2 rounded font-label-sm text-label-sm hover:opacity-90 transition-opacity shadow-sm"
      aria-haspopup="true"
    >
      <span class="material-symbols-outlined text-[18px]">download</span>
      Descargar CV
      <span class="material-symbols-outlined text-[18px] group-hover:rotate-180 transition-transform">
        expand_more
      </span>
    </button>
    <div
      class="absolute right-0 top-full pt-2 w-48 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all"
    >
      <div class="bg-surface-container-lowest border border-border-subtle rounded-lg shadow-lg overflow-hidden">
        {
          cvDownloads.map((cv) => (
            <a
              class="flex items-center justify-between gap-2 px-4 py-3 text-on-surface-variant hover:bg-surface-container hover:text-primary transition-colors"
              href={`${base}/${cv.file}`}
              download
            >
              <span class="font-label-sm text-label-sm">{cv.label}</span>
              <span class="font-label-caps text-label-caps text-outline">PDF</span>
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Botón menú móvil -->
  <button id="mobile-menu-btn" class="md:hidden text-primary" aria-label="Abrir menú">
    <span class="material-symbols-outlined text-2xl">menu</span>
  </button>
</nav>

<!-- Menú móvil desplegable -->
<div
  id="mobile-menu"
  class="hidden md:hidden bg-surface-container-lowest border-b border-border-subtle sticky top-20 w-full z-40 max-w-container-max mx-auto"
>
  <div class="flex flex-col px-margin-mobile py-4 gap-1">
    {
      navLinks.map((link) => (
        <a class="nav-link-m" href={link.href} data-nav={link.href.slice(1)} data-mobile-link>
          {link.label}
        </a>
      ))
    }
    <div class="border-t border-border-subtle mt-2 pt-3 flex flex-col gap-2">
      <span class="font-label-caps text-label-caps text-outline uppercase pl-3">Descargar CV</span>
      {
        cvDownloads.map((cv) => (
          <a
            class="flex items-center gap-2 pl-3 py-2 text-primary font-label-sm text-label-sm"
            href={`${base}/${cv.file}`}
            download
            data-mobile-link
          >
            <span class="material-symbols-outlined text-[18px]">download</span>
            {cv.label} <span class="text-outline">(PDF · {cv.lang})</span>
          </a>
        ))
      }
    </div>
  </div>
</div>

<script>
  // Menú móvil
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  document
    .querySelectorAll('[data-mobile-link]')
    .forEach((l) => l.addEventListener('click', () => menu?.classList.add('hidden')));

  // Scroll-spy: resalta el enlace de la sección visible
  const sections = [...document.querySelectorAll<HTMLElement>('main section[id]')];
  const links = [...document.querySelectorAll<HTMLElement>('[data-nav]')];
  const visible = new Set<string>();

  const setActive = (id: string) => {
    for (const l of links) l.classList.toggle('is-active', l.dataset.nav === id);
  };

  if (sections.length && links.length) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) visible.add(e.target.id);
          else visible.delete(e.target.id);
        }
        // El primero (en orden del documento) que esté visible en la banda central
        const active = sections.find((s) => visible.has(s.id));
        if (active) setActive(active.id);
      },
      { rootMargin: '-45% 0px -45% 0px', threshold: 0 }
    );
    sections.forEach((s) => io.observe(s));
  }
</script>
